# Supabase 프로젝트 설정 (anon/publishable key만 사용 — service key는 절대 여기 넣지 말 것)
# VITE_ 접두어: 브라우저 번들에 포함됨 (관리자 로그인 화면 등 클라이언트에서 직접 Supabase를 호출할 때 사용)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# 접두어 없음: Vercel 서버리스 함수(api/events.ts) 전용, 브라우저에 노출되지 않음.
# 값 자체는 위 VITE_ 버전과 동일한 anon/publishable key를 넣으면 된다.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# api/admin/trigger-run.ts 전용 — 브라우저에 절대 노출되지 않음
ADMIN_API_SECRET=
TAILSCALE_FUNNEL_URL=
# 관리자로 허용할 이메일 목록. 여러 명이면 콤마로 구분 (예: a@x.com,b@y.com)
ADMIN_EMAILS=
